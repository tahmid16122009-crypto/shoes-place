<!DOCTYPE html>
<html>
<head>
<title>Home</title>
</head>
<body>

{% if not user %}
<div>
  <h3>Login</h3>
  <form action="/login" method="POST">
    <input name="name" placeholder="Name">
    <input name="phone" placeholder="Phone">
    <button>Login</button>
  </form>

  <form action="/login" method="POST">
    <input type="hidden" name="name" value="Guest">
    <input type="hidden" name="phone" value="000">
    <button>Skip</button>
  </form>
</div>
{% else %}
<p>Welcome {{user.name}}</p>
{% endif %}

<hr>

<h2>Products</h2>

{% for p in products %}
<div>
  <img src="{{p.image}}" width="120"><br>
  {{p.name}} - {{p.price}}<br>
  <a href="/add/{{p.id}}">Add to Cart</a>
</div>
<hr>
{% endfor %}

<!-- NAV -->
<a href="/home">Home</a> |
<a href="/cart">Cart</a> |
<a href="/orders">Ordered</a> |
<a href="/me">Me</a>

</body>
</html>